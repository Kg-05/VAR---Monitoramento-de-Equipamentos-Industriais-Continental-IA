{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "CommonJS",
    "lib":               ["ES2022"],
    "rootDir":           "./src",
    "outDir":            "./dist",
    "strict":            false,
    "esModuleInterop":   true,
    "resolveJsonModule": true,
    "skipLibCheck":      true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl":           ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}