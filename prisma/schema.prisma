generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Papel {
  ADMIN_CENTRAL
  ADMIN_EMPRESA
  FUNCIONARIO
}

enum StatusLicenca { 
  ATIVA 
  EXPIRADA 
  PENDENTE 
  SUSPENSA 
}

enum TipoLicenca {
  BASICO
  EMPRESARIAL
  PREMIUM
}

enum StatusPagamento { 
  PENDENTE 
  CONCLUIDO 
  FALHOU 
  REEMBOLSADO 
}

enum StatusEquipamento { 
    OPERACIONAL
    MANUTENCAO
}

enum SeveridadeAlerta { 
    BAIXO
    MEDIO
    ALTO
}

model Empresa {
  id            String     @id @default(uuid())
  nome          String
  nif           String?
  endereco      String?
  contacto      String?
  email         String?    @unique
  criadoEm      DateTime   @default(now())
  atualizadoEm  DateTime   @updatedAt
  usuarios      Usuario[]
  licencas      Licenca[]
  equipamentos  Equipamento[]
  pagamentos    Pagamento[]
  logs          Log[]

  Alerta Alerta[]
}

model Usuario {
  id            String     @id @default(uuid())
  email         String
  senhaHash     String
  nome          String?
  papel         Papel      @default(FUNCIONARIO)
  empresaId     String?
  ativo         Boolean    @default(true)
  criadoEm      DateTime   @default(now())
  atualizadoEm  DateTime   @updatedAt
  empresa       Empresa?   @relation(fields: [empresaId], references: [id])
  alertasLidos  Alerta[]   @relation("LidosPor")
  avarias       Avaria[]   
  @@index([email])
  Avaria Avaria[] @relation("LidosPor")
  Alerta Alerta[]
  Log Log[]
}

model Licenca {
  id            String        @id @default(uuid())
  empresaId     String
  plano         TipoLicenca   @default(BASICO)
  status        StatusLicenca @default(PENDENTE)
  maxFuncionarios Int        @default(2)
  inicioEm      DateTime?
  expiraEm      DateTime?
  criadoEm      DateTime      @default(now())
  atualizadoEm  DateTime      @updatedAt
  empresa       Empresa       @relation(fields: [empresaId], references: [id])
  pagamentos    Pagamento[]
}

model Pagamento {
  id            String          @id @default(uuid())
  empresaId     String
  licencaId     String?
  valor         Float
  moeda         String          @default("AOA")
  status        StatusPagamento @default(PENDENTE)
  referenciaProvedor String?
  criadoEm      DateTime        @default(now())
  atualizadoEm  DateTime        @updatedAt
  empresa       Empresa         @relation(fields: [empresaId], references: [id])
  licenca       Licenca?        @relation(fields: [licencaId], references: [id])
}

model Equipamento {
  id            String            @id @default(uuid())
  empresaId     String
  nome          String
  modelo        String?
  numeroSerie   String?           @unique
  localizacao   String?
  status        StatusEquipamento @default(OPERACIONAL)
  criadoEm      DateTime          @default(now())
  atualizadoEm  DateTime          @updatedAt
  empresa       Empresa           @relation(fields: [empresaId], references: [id])
  dispositivos  Dispositivo[]
  avarias       Avaria[]
}

model Dispositivo {
  id            String    @id @default(uuid())
  equipamentoId String
  nome          String
  tipo          String?
  rtspUrl       String?
  ativo         Boolean   @default(true)
  criadoEm      DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt
  equipamento   Equipamento @relation(fields: [equipamentoId], references: [id])
  avarias       Avaria[]
}

model Avaria {
  id            String          @id @default(uuid())
  equipamentoId String
  dispositivoId String?
  detectadoPor  String?
  descricao     String?
  confianca     Float?
  severidade    SeveridadeAlerta
  imagemUrl     String?
  criadoEm      DateTime        @default(now())
  resolvido     Boolean         @default(false)
  resolvidoEm   DateTime?
  resolvidoPorId String?
  equipamento   Equipamento     @relation(fields: [equipamentoId], references: [id])
  dispositivo   Dispositivo?    @relation(fields: [dispositivoId], references: [id])
  resolvidoPor  Usuario?        @relation("LidosPor", fields: [resolvidoPorId], references: [id])
  alertas       Alerta[]

  Usuario Usuario[]
}

model Alerta {
  id            String          @id @default(uuid())
  avariaId      String
  empresaId     String
  criadoEm      DateTime        @default(now())
  lidoPorId     String?
  lidoEm        DateTime?
  mensagem      String?
  severidade    SeveridadeAlerta 
  reconhecido   Boolean         @default(false)
  reconhecidoEm DateTime?
  avaria        Avaria          @relation(fields: [avariaId], references: [id])
  empresa       Empresa         @relation(fields: [empresaId], references: [id])
  lidoPor       Usuario?        @relation(fields: [lidoPorId], references: [id])

  Usuario Usuario[] @relation("LidosPor")
}

model Log {
  id            String     @id @default(uuid())
  empresaId     String?
  usuarioId     String?
  nivel         String
  acao          String
  dados         Json?
  criadoEm      DateTime   @default(now())
  empresa       Empresa?   @relation(fields: [empresaId], references: [id])
  usuario       Usuario?   @relation(fields: [usuarioId], references: [id])
}