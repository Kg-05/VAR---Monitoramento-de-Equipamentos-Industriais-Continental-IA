{
  "name": "industrial-monitoring-api",
  "version": "1.0.0",
  "description": "API de monitoramento de equipamentos industriais",
  "main": "dist/server.js",
  "scripts": {
    "dev":         "tsx watch src/server.ts",
    "build":       "tsc",
    "start":       "node dist/server.js",
    "db:migrate":  "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed":     "tsx prisma/seed.ts",
    "db:studio":   "prisma studio",
    "db:reset":    "prisma migrate reset --force && tsx prisma/seed.ts",
    "test":        "vitest",
    "test:ui":     "vitest --ui",
    "lint":        "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs":       "^2.4.3",
    "express":        "^4.21.0",
    "jsonwebtoken":   "^9.0.2",
    "zod":            "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs":     "^2.4.6",
    "@types/express":      "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node":         "^22.0.0",
    "@types/supertest":    "^6.0.2",
    "prisma":              "^5.22.0",
    "supertest":           "^7.0.0",
    "tsx":                 "^4.19.0",
    "typescript":          "^5.6.0",
    "vitest":              "^2.1.0"
  }
}
