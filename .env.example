# .env.example — copie para .env e preencha os valores
# Exemplo de DATABASE_URL para PostgreSQL:
DATABASE_URL="postgresql://<DB_USE>:<DB_PASS>@<DB_HOST>:<DB_PORT>/<DB_NAME>"

# JWT secret usado para assinar tokens JWT
JWT_SECRET="sua_chave_secreta_aqui"

# Porta da aplicação
PORT=4000

# Instruções rápidas
# 1) Copie este arquivo para .env e substitua os placeholders.
#    Exemplo (substitua pelos seus valores):
#    DATABASE_URL="postgresql://postgres:MinhaSenhaAqui@localhost:5432/var_db"

# 2) Gerar o cliente Prisma (usa versão compatível do projeto):
#    npx prisma@6.15.0 generate

# 3) Rodar migrações (criar tabelas no DB):
#    npx prisma@6.15.0 migrate dev --name init

# 4) Executar seeds (se houver):
#    npx ts-node prisma/seed.ts
#    npx ts-node prisma/seed-admin.ts   # se existir

# 5) Iniciar o servidor em modo dev:
#    npm run dev

# Observações:
# - Não compartilhe este arquivo com credenciais em canais públicos.
# - Se tiver problemas com bloqueio de arquivos do Prisma em Windows, pare processos Node
#   (taskkill /F /IM node.exe) antes de rodar os comandos acima.
