# =============================================================
# Variáveis de ambiente — copie para .env e preencha os valores
# =============================================================

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/var"

# JWT
JWT_SECRET="substitua-por-uma-chave-secreta-longa-e-aleatoria"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Servidor
PORT=3333
NODE_ENV="development"
